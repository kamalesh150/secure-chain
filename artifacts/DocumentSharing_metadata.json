		"devdoc": {
			"details": "Decentralized document sharing, certificate storage, and verification system.      Uses IPFS hashes for file references and keccak256 for integrity verification. NEW in this version:  - fileHash field for on-chain integrity verification  - description / category fields per document  - Access expiry timestamps (0 = no expiry)  - verifyDocument()  – public verification without needing access  - getAccessDetails() – returns grantedAt + expiresAt for an address  - DocumentVerified event  - isAccessExpired() helper",
			"kind": "dev",
			"methods": {
				"grantAccess(uint256,address,uint256)": {
					"params": {
						"_documentId": "ID of the document.",
						"_expiresAt": "Unix timestamp for expiry; pass 0 for no expiry.",
						"_recipient": "Address to grant access to."
					}
				},
				"uploadDocument(string,string,string,string,bytes32)": {
					"params": {
						"_category": "Category string (e.g. \"certificate\", \"contract\").",
						"_description": "Short human-readable title / description.",
						"_fileHash": "keccak256 of raw file bytes, computed client-side.",
						"_fileName": "Original file name.",
						"_ipfsHash": "IPFS CID of the file."
					}
				},
				"verifyDocument(uint256,string,bytes32)": {
					"params": {
						"_documentId": "ID of the document to verify.",
						"_fileHash": "keccak256 of file bytes; pass bytes32(0) to skip check.",
						"_ipfsHash": "IPFS CID to compare against the stored one."
					},
					"returns": {
						"storedOwner": "  The owner address recorded on-chain.",
						"uploadTime": "   When the document was originally uploaded.",
						"valid": "        True if both provided values match stored values."
					}
				}
			},
			"title": "DocumentSharing",
			"version": 1
		},
		"userdoc": {
			"kind": "user",
			"methods": {
				"checkAccess(uint256,address)": {
					"notice": "Check if an address currently has valid (non-expired) access."
				},
				"deleteDocument(uint256)": {
					"notice": "Soft-delete a document (only owner)."
				},
				"getAccessDetails(uint256,address)": {
					"notice": "Get full access details for a user on a document."
				},
				"getDocument(uint256)": {
					"notice": "Retrieve full document details. Caller must be owner or have valid access."
				},
				"getMyDocuments(address)": {
					"notice": "Get all document IDs owned by an address."
				},
				"getSharedWithMe(address)": {
					"notice": "Get all document IDs shared with an address."
				},
				"getTotalDocuments()": {
					"notice": "Total number of documents ever uploaded."
				},
				"grantAccess(uint256,address,uint256)": {
					"notice": "Grant view access to a recipient, optionally with an expiry."
				},
				"isAccessExpired(uint256,address)": {
					"notice": "Check whether an address's access has expired."
				},
				"revokeAccess(uint256,address)": {
					"notice": "Revoke view access from a recipient."
				},
				"uploadDocument(string,string,string,string,bytes32)": {
					"notice": "Upload a new document / certificate."
				},
				"verifyDocument(uint256,string,bytes32)": {
					"notice": "Verify a document by matching the provided IPFS hash and/or file hash.         This is public — anyone can call it for certificate verification."
				}
			},
			"version": 1
		}
